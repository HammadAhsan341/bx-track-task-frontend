                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data && Array.isArray(data.items) && data.items.length > 0) {",
                  "  pm.collectionVariables.set('customer_id', data.items[0].id);",
                  "}",
                  "",
                  "if (data && data.nextCursor) {",
                  "  pm.collectionVariables.set('next_cursor', data.nextCursor);",
                  "}",
                  "",
                  "pm.test('Paginated shape is valid', function () {",
                  "  pm.expect(data).to.have.property('items');",
                  "  pm.expect(Array.isArray(data.items)).to.eql(true);",
