{
  "info": {
    "_postman_id": "155502f8-4319-4fbc-a0c5-f3b349d517bf",
    "name": "Multi Tenant CRM API (Local)",
    "description": "Ready-to-import collection for the NestJS CRM server.\n\nHow to use:\n1. Start API locally (default: http://localhost:4000).\n2. Run `npm run seed` and copy an admin `x-user-id` from seed output.\n3. In collection variables, set `x_user_id` to that admin ID.\n4. Run requests in order: Health -> Users -> Customers -> Notes -> Activity Logs.\n\nThis collection auto-saves useful IDs to collection variables:\n- `admin_user_id`\n- `member_user_id`\n- `created_user_id`\n- `customer_id`\n- `next_cursor`\n- `note_id`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Health is ok', function () {",
                  "  pm.expect(data.status).to.eql('ok');",
                  "});"
                ],
                "id": "ee5e2f6d-6fbc-4ac8-a49b-efd9546877f6"
              }
            }
          ],
          "id": "03fea460-785d-4b59-a756-bd78f1e60c95",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Public health endpoint. No auth header required."
          },
          "response": []
        }
      ],
      "id": "13a30340-a707-4b53-8fbf-19ad1a2bd099"
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data && data.id) {",
                  "  pm.collectionVariables.set('admin_user_id', data.id);",
                  "}",
                  "",
                  "pm.test('User object exists', function () {",
                  "  pm.expect(data).to.have.property('id');",
                  "  pm.expect(data).to.have.property('organizationId');",
                  "});"
                ],
                "id": "386ad2bc-0d74-4f57-9a91-275165992544"
              }
            }
          ],
          "id": "732c2f5d-d57b-4af0-8932-bb7dc95c8ef9",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{x_user_id}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "me"
              ]
            },
            "description": "Verifies your current auth identity from `x-user-id`."
          },
          "response": []
        },
        {
          "name": "List Users (Same Organization)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const users = pm.response.json();",
                  "if (Array.isArray(users)) {",
                  "  const admin = users.find((u) => u.role === 'admin');",
                  "  const member = users.find((u) => u.role === 'member');",
                  "  if (admin && admin.id) pm.collectionVariables.set('admin_user_id', admin.id);",
                  "  if (member && member.id) pm.collectionVariables.set('member_user_id', member.id);",
                  "}",
                  "",
                  "pm.test('Response is an array', function () {",
                  "  pm.expect(Array.isArray(users)).to.eql(true);",
                  "});"
                ],
                "id": "a4433d27-2210-4729-ac80-b018e117a94c"
              }
            }
          ],
          "id": "6e01435d-90c4-48bf-a66c-1b0d2d7158df",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{x_user_id}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            },
            "description": "Lists users in the same organization as the acting user."
          },
          "response": []
        },
        {
          "name": "Create User (Admin Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data && data.id) {",
                  "  pm.collectionVariables.set('created_user_id', data.id);",
                  "  if (data.role === 'member') {",
                  "    pm.collectionVariables.set('member_user_id', data.id);",
                  "  }",
                  "}",
                  "",
                  "pm.test('Created user has id', function () {",
                  "  pm.expect(data).to.have.property('id');",
                  "});"
                ],
                "id": "f703cc17-9bf6-47c3-9572-b2e3abb6a774"
              }
            }
          ],
          "id": "5455c3d0-f911-49e8-8fd5-428da52343a8",
